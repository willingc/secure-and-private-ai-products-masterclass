{
  "name": "Python Codespace with UV",
  "image": "mcr.microsoft.com/devcontainers/python:3.13",
  "onCreateCommand": "curl -LsSf https://astral.sh/uv/install.sh | sh && uv venv && UV_HTTP_TIMEOUT=300 uv pip install -r requirements.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspaces/secure-and-private-ai-products-masterclass/.venv/bin/python",
        "python.terminal.activateEnvInCurrentTerminal": true
      }
    }
  }
}
